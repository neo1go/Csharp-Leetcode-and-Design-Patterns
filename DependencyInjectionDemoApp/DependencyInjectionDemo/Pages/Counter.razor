@page "/counter"

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @counterService.CurrentCount</p>

<button class="btn btn-primary" @onclick="IncrementNow">Click me</button>         <!-- Zuweisung des Buttons -->

@code {
    //Wechsel zum c# Code

    [Inject]
    private CounterService  ? counterService{ get; set; }    //Konstruktor für CounterService

    private void IncrementNow()
    {
        counterService.IncrementCount();// Hier wird die Methode der Klasse CounterService auf dem Objekt counterService ausgeführt
    }
}
