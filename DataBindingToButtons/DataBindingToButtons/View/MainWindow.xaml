<Window x:Class="DataBindingToButtons.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataBindingToButtons" xmlns:viewmodel="clr-namespace:DataBindingToButtons.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="500">

    <Window.DataContext>
        <viewmodel:MainViewModel/>
    </Window.DataContext>
    
    
    <Grid Background="#f1f3f5" >
        <Border HorizontalAlignment="Center" CornerRadius="10" Background="White" BorderThickness="1" BorderBrush="#adb5bd" Height="300" Width="250" Margin="0,20,0,80">
            <TextBlock VerticalAlignment="Center" Text="{Binding View.CurrentItem }" FontSize="100" Foreground="#495057" HorizontalAlignment="Center"></TextBlock>
        </Border>

        <Button Content="Previous" Command="{Binding MovePreviousCommand}" Margin="100,0,233,60" Padding="5" VerticalAlignment="Bottom" Background="White" BorderThickness="1" Width="100" ></Button>
        <Button Content="Next" Command="{Binding MoveNextCommand}" Margin="230,0,100,60" Padding="5" VerticalAlignment="Bottom" Background="White" BorderThickness="1" Width="100" ></Button>
        
    </Grid>
</Window>
