<Window x:Class="ListViewBeispielXAML.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ListViewBeispielXAML"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DataGrid ItemsSource="{Binding LoggerEntries}" AutoGenerateColumns="False"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Startzeit" Binding="{Binding Startzeit, StringFormat='{}{0:HH:mm:ss}'}"/>
                <DataGridTextColumn Header="Endzeit" Binding="{Binding Endzeit, StringFormat='{}{0:HH:mm:ss}'}"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Abteilung" Binding="{Binding Abteilung}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
